<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Master Suite" verbose="1" parallel="classes" thread-count="3">
    <parameter name="browser" value="chrome" />
    <parameter name="env" value="prod" />
    <test name="Smoke Tests">

        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="com.sauceDemo.tests.LoginTests" />
            <class name="com.sauceDemo.tests.CheckoutTests" />
            <class name="api.tests.AuthTests"/>
            <class name="api.tests.PostTests"/>
        </classes>
    </test>

</suite>