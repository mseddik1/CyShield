<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Smoke Tests API v1" verbose="1" parallel="classes" thread-count="4">
    <parameter name="env" value="prod" />
    <test name="Smoke Tests">

        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="api.tests.AuthTests"/>
            <class name="api.tests.PostTests"/>
        </classes>
    </test>
</suite>

